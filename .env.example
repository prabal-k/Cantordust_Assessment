# LLM provider switch: "gemini" (default), "groq", or "openrouter"
LLM_PROVIDER=gemini

# Get free key from https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Get free key from https://console.groq.com/keys
GROQ_API_KEY=

# Get free key from https://openrouter.ai/keys ; free models listed at
# https://openrouter.ai/models?max_price=0
OPENROUTER_API_KEY=

# Optional model overrides
GEMINI_MODEL=gemini-2.5-flash-lite
GROQ_MODEL=llama-3.3-70b-versatile
OPENROUTER_MODEL=qwen/qwen3-next-80b-a3b-instruct:free

# Optional: LangSmith tracing.
# Sign up free at https://smith.langchain.com, copy an API key, then uncomment
# all three. Sidebar caption in Streamlit flips to "tracing ON".
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=cantordust-nepal-compliance
