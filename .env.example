# LLM provider switch: "gemini" (default) or "groq"
LLM_PROVIDER=gemini

# Get free key from https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Get free key from https://console.groq.com/keys
GROQ_API_KEY=

# Optional model overrides
GEMINI_MODEL=gemini-2.5-flash
GROQ_MODEL=llama-3.3-70b-versatile

# Optional: LangSmith tracing.
# Sign up free at https://smith.langchain.com, copy an API key, then uncomment
# all three. Sidebar caption in Streamlit flips to "tracing ON".
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=cantordust-nepal-compliance
